---
import type { Artwork } from '../lib/artwork';

interface Props {
  artworks: Artwork[];
}

const { artworks } = Astro.props;
---
{artworks.length > 0 && (
  <div class="gallery">
    {artworks.map((art) => (
      <figure class="artwork">
        {art.panels?.length ? (
          <div class="panels">
            {art.panels.map((p) => (
              <img src={p.image} alt={`${art.title}${p.title ? ` — ${p.title}` : ''}`} loading="lazy" />
            ))}
          </div>
        ) : art.image ? (
          art.link ? (
            <a class="art-link" href={art.link}>
              <img src={art.image} alt={`${art.title} — ${art.artist}`} loading="lazy" />
            </a>
          ) : (
            <img src={art.image} alt={`${art.title} — ${art.artist}`} loading="lazy" />
          )
        ) : art.link ? (
          <a class="art-link placeholder" href={art.link}>
            <span>In copyright &mdash; view&nbsp;&#8599;</span>
          </a>
        ) : null}
        <figcaption>
          {art.link ? (
            <a class="art-title" href={art.link}>{art.title}</a>
          ) : (
            <span class="art-title">{art.title}</span>
          )}
          <span class="art-meta">{art.artist}{art.date && `, ${art.date}`}</span>
        </figcaption>
      </figure>
    ))}
  </div>
)}
