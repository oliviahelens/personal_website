---
import type { Artwork } from '../lib/artwork';

interface Props {
  artworks: Artwork[];
}

const { artworks } = Astro.props;
---
{artworks.length > 0 && (
  <div class="gallery">
    {artworks.map((art) => (
      <figure class="artwork">
        <a class="art-link" href={art.link}>
          <img src={art.image} alt={`${art.title} — ${art.artist}`} loading="lazy" />
        </a>
        <figcaption>
          <a class="art-title" href={art.link}>{art.title}</a>
          <span class="art-meta">{art.artist}{art.date && `, ${art.date}`}</span>
        </figcaption>
      </figure>
    ))}
  </div>
)}
