---
import Base from '../layouts/Base.astro';
import { fetchCovers } from '../lib/watching';

const films = [
  "Good Will Hunting",
  "Dead Poets Society",
  "12 Angry Men",
  "Spirited Away",
  "Howl's Moving Castle",
  "The Boy and the Heron",
  "The Big Short",
  "Ferris Bueller's Day Off",
  "Moneyball",
  "Top Gun",
  "Ford v Ferrari",
  "Fight Club",
  "The Social Network",
  "The Martian",
  "The Imitation Game",
  "Whiplash",
  "Vertigo",
  "The Good, the Bad and the Ugly",
  "Dune",
  "Her",
];

const television = [
  "Avatar: The Last Airbender",
  "Pantheon",
  "The Queen's Gambit",
  "Invincible",
  "Mad Men",
  "Death Note",
  "Suits",
  "Severance",
  "Silicon Valley",
  "The Wire",
];

const covers = await fetchCovers(films, television);
---
<Base
  title="Watching — Olivia H. Scharfman"
  description="Films and television Olivia H. Scharfman loves."
>
  <h1>Watching</h1>

  <section class="shelf">
    <h2>Films</h2>
    <ul class="watch-grid">
      {covers.films.map((item) => (
        <li class="watch">
          {item.cover ? (
            <img class="cover" src={item.cover} alt={item.title} loading="lazy" />
          ) : (
            <div class="cover cover-fallback">{item.title}</div>
          )}
          <span class="watch-title">{item.title}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="shelf">
    <h2>Television</h2>
    <ul class="watch-grid">
      {covers.television.map((item) => (
        <li class="watch">
          {item.cover ? (
            <img class="cover" src={item.cover} alt={item.title} loading="lazy" />
          ) : (
            <div class="cover cover-fallback">{item.title}</div>
          )}
          <span class="watch-title">{item.title}</span>
        </li>
      ))}
    </ul>
  </section>
</Base>
