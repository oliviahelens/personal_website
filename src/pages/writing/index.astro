---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title="Writing — Olivia Scharfman">
  <h1>Writing</h1>
  <p class="subtitle">Essays and notes.</p>

  {posts.length === 0 ? (
    <p>Nothing posted yet. Drop a Markdown file into <code>src/content/writing/</code>.</p>
  ) : (
    <ul class="index">
      {posts.map((post) => (
        <li>
          <a href={`/writing/${post.id}/`}>{post.data.title}</a>
          <span class="meta">{fmt(post.data.date)}</span>
          {post.data.description && <span class="desc">{post.data.description}</span>}
        </li>
      ))}
    </ul>
  )}
</Base>
