---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import { fetchGallery } from '../lib/artwork';
import { ARTISTS } from '../lib/favorites';

const artworks = await fetchGallery(ARTISTS);
---
<Base
  title="Gallery — Olivia H. Scharfman"
  description="A few works of art Olivia H. Scharfman loves, pulled from open-access museum collections."
>
  <h1>Gallery</h1>

  <p>Works I keep coming back to &mdash; a few favorites from each of a handful
  of artists. Most are public-domain scans from <a
  href="https://commons.wikimedia.org/">Wikimedia Commons</a>, with a few from
  <a href="https://www.metmuseum.org/">The Met</a>. Where a piece lives in a
  collection online, its title links back to it.</p>

  <Gallery artworks={artworks} />

  {artworks.length === 0 && (
    <p>The gallery isn’t loading right now &mdash; it pulls from the museums’
    open-access APIs at build time, and one of them may be having a moment.</p>
  )}
</Base>
