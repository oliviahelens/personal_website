---
import Base from '../layouts/Base.astro';
import Gallery from '../components/Gallery.astro';
import { fetchGallery } from '../lib/artwork';
import { ARTISTS } from '../lib/favorites';

const artworks = await fetchGallery(ARTISTS);

// Contemporary artists Olivia loves — linked out rather than hosted (their work
// is under copyright, so we credit and point to it).
const contemporary = [
  { name: 'Ken Salaz', url: 'https://kensalaz.com' },
  { name: 'Micah Ofstedahl', url: 'https://www.micahofstedahl.com' },
  { name: 'Tomás Sánchez', url: 'https://www.tomassanchez.com' },
  { name: 'WP Storck', url: 'https://www.williamstorck.com' },
  { name: 'Devin Michael Roberts', url: 'https://devinrobertsstudio.com' },
  { name: 'Renato Muccillo', url: 'https://renatomuccillo.com' },
  { name: 'Ksenya Verse', url: 'https://www.ksenyaverse.com' },
  { name: 'Sara Linda Poly', url: 'https://www.saralindapolystudio.com' },
  { name: 'Jenny Kiehn', url: 'https://jennykiehn.com' },
  { name: 'Sofia Sharbat', url: 'https://studiosharbat.com' },
  { name: 'Dot Walker', url: 'https://www.dotwalker.co.uk' },
  { name: 'Annie Stegg', url: 'https://www.anniestegg.com' },
  { name: 'Ella Baudinet', url: 'https://www.ellabaudinet.com' },
  { name: 'Luke Leal', url: 'https://www.lukelealart.com' },
  { name: 'Michael Albrechtsen', url: 'https://michaelalbrechtsen.com' },
  { name: 'Erik Koeppel', url: 'https://www.erikkoeppel.com' },
  { name: 'Thomas Kegler', url: 'https://thomaskegler.com' },
  { name: 'D. Eleinne Basa', url: 'https://www.eleinnebasa.com' },
  { name: 'Chris Bacon', url: 'https://chrisbacon.com' },
  { name: 'Justin T. Worrell', url: 'https://www.justintworrell.com' },
  { name: 'Odd Nerdrum', url: 'https://nerdrum.com' },
  { name: 'Mark Maggiori', url: 'https://markmaggiori.com' },
  { name: 'Jef Bourgeau', url: 'https://detroitmona.wixsite.com/artgarage' },
  { name: 'Erin Hanson', url: 'https://www.erinhanson.com' },
  { name: 'Hallie Packard', url: 'https://www.halliepackardart.com' },
];

// A few of my own paintings — self-hosted in /public/artwork alongside the
// gallery pieces (so the prebuild optimizer downsizes the photos), newest
// first, shown at the very bottom of the page.
const ownWork = [
  {
    src: '/artwork/scharfman-dream.jpg',
    alt: 'Oil painting of a misty river winding toward a low moon, soft trees along the banks',
    caption: '2026',
  },
  {
    src: '/artwork/scharfman-dream3.jpeg',
    alt: 'Oil painting of a grove of trees beside still water under a soft pink sunset',
    caption: '2026',
  },
  {
    src: '/artwork/scharfman-estonia.jpeg',
    alt: 'Painting of a still blue bog lake dotted with small pine-covered islands',
    caption: 'Estonia, 2022',
  },
  {
    src: '/artwork/scharfman-half-moon-bay.jpeg',
    alt: 'Painting of waves breaking on coastal rocks below a bluff, birds over the sea',
    caption: 'Half Moon Bay, 2020',
  },
];
---
<Base
  title="Gallery — Olivia H. Scharfman"
  description="A few works of art Olivia H. Scharfman loves, pulled from open-access museum collections."
>
  <h1>Gallery</h1>

  <p>This is a gallery of artwork from some of my favorite visual artists of
  all time. Below is also a list of some of my favorite contemporary artists
  and some of my own attempts.</p>

  <Gallery artworks={artworks} />

  {artworks.length === 0 && (
    <p>The gallery isn’t loading right now &mdash; it pulls from the museums’
    open-access APIs at build time, and one of them may be having a moment.</p>
  )}

  <section class="contemporary">
    <h2>Contemporary artists I love</h2>
    <p class="contemporary-list">
      {contemporary.map((a, i) => (
        <>{i > 0 && ' · '}<a href={a.url}>{a.name}</a></>
      ))}
    </p>
  </section>

  <section class="own-work">
    <h2>Some of my own attempts</h2>
    <div class="gallery">
      {ownWork.map((p) => (
        <figure class="artwork">
          <img src={p.src} alt={p.alt} loading="lazy" />
          <figcaption>{p.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</Base>
