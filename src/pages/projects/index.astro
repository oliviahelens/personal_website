---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Projects — Olivia Scharfman">
  <h1>Projects</h1>
  <p class="subtitle">Things I've made.</p>

  {projects.length === 0 ? (
    <p>Nothing here yet. Drop a Markdown file into <code>src/content/projects/</code>.</p>
  ) : (
    <ul class="index">
      {projects.map((project) => (
        <li>
          {project.data.url
            ? <a href={project.data.url}>{project.data.title}</a>
            : <span>{project.data.title}</span>}
          {project.data.description && <span class="desc">{project.data.description}</span>}
        </li>
      ))}
    </ul>
  )}
</Base>
