---
import Base from '../layouts/Base.astro';
import BookShelf from '../components/BookShelf.astro';
import { fetchReadingShelves } from '../lib/goodreads';

const { currentlyReading, read, favorites } = await fetchReadingShelves();
const hasAny = currentlyReading.length + read.length + favorites.length > 0;
const profile = 'https://www.goodreads.com/user/show/178728194-olivia-scharfman';
---
<Base
  title="Bookshelves — Olivia H. Scharfman"
  description="What Olivia H. Scharfman is reading and has read — pulled from Goodreads."
>
  <h1>Bookshelves</h1>

  <p>Pulled from my <a href={profile}>Goodreads</a>.</p>

  <BookShelf title="Currently reading" books={currentlyReading} showRating={false} />
  <BookShelf title="Favorites" books={favorites} />
  <BookShelf title="Read" books={read} />

  {!hasAny && (
    <p>Nothing is loading from Goodreads right now &mdash; my shelves live
    <a href={profile}>over here</a>.</p>
  )}
</Base>
